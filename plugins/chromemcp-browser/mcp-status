#!/usr/bin/env bash
# Human-readable health report for the ChromeMCP MCP server.
#
# Detects:
#   * supervised mode (systemd user unit installed)   → systemctl status
#   * ad-hoc background mode (PID file present)       → liveness + curl
#   * not running at all                              → suggest ./mcp-up
#
# Exit codes:
#   0  service is up and the public port answers
#   1  service appears down (PID gone / not listening)
#   2  unknown / can't tell (systemd not available AND no PID file)
set -euo pipefail

SELF="$(readlink -f "$0")"
REPO_ROOT="$(dirname "$SELF")"
UNIT_NAME="chromemcp.service"
PORT="${PORT:-8931}"
HOST="${HOST:-127.0.0.1}"
HEALTH_URL="http://${HOST}:${PORT}/healthz"
PID_FILE="$REPO_ROOT/mcp/.playwright.pid"

is_supervised() {
  systemctl --user is-system-running >/dev/null 2>&1 || return 1
  systemctl --user list-unit-files --type=service 2>/dev/null | grep -q "^$UNIT_NAME"
}

fetch_health() {
  curl -fsS --max-time 3 "$HEALTH_URL"
}

print_health_summary() {
  local body="$1"
  python3 - "$body" <<'PY' || true
import json
import sys

try:
    data = json.loads(sys.argv[1])
except Exception:
    raise SystemExit(0)

visible = data.get("visibleInteractions") or {}
cdp = data.get("cdp") or {}
if visible:
    print(f"Visible interactions: {'enabled' if visible.get('enabled') else 'disabled'}")
if cdp:
    print(f"CDP healthy: {'yes' if cdp.get('healthy') else 'no'} ({cdp.get('endpoint', 'unknown')})")
PY
}

if is_supervised; then
  echo "Mode: supervised (systemd --user)"
  echo ""
  systemctl --user status "$UNIT_NAME" --no-pager --lines=8 || true
  echo ""
  if HEALTH_BODY="$(fetch_health)"; then
    echo "Endpoint: $HEALTH_URL — OK"
    print_health_summary "$HEALTH_BODY"
    exit 0
  else
    echo "Endpoint: $HEALTH_URL — NOT responding"
    exit 1
  fi
fi

# Ad-hoc mode fallback.
echo "Mode: ad-hoc (no systemd unit installed; ./mcp-up backgrounds the proxy)"
echo ""
if [ -f "$PID_FILE" ]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || echo)"
  if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    echo "PID file: $PID_FILE (alive, PID $PID)"
  else
    echo "PID file: $PID_FILE (STALE — process $PID is gone)"
  fi
else
  echo "PID file: not present"
fi
echo ""

if HEALTH_BODY="$(fetch_health)"; then
  echo "Endpoint: $HEALTH_URL — OK"
  print_health_summary "$HEALTH_BODY"
  exit 0
else
  echo "Endpoint: $HEALTH_URL — NOT responding"
  echo ""
  if [ ! -f "$PID_FILE" ]; then
    echo "Hint: run ./mcp-up to start the server."
  fi
  exit 1
fi
