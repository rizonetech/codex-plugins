#!/usr/bin/env bash
# WSL wrapper: triggers the Windows-side bridge setup with UAC elevation.
# The Windows side will pop a UAC dialog. Approve it to proceed.
#
# Usage:
#   ./setup-bridge          - install/refresh the bridge
#   ./setup-bridge /remove  - tear it down
set -euo pipefail
SELF="$(readlink -f "$0")"
DIR="$(dirname "$SELF")"
CMD_WIN_PATH="$(wslpath -w "$DIR/Setup-Bridge.cmd")"
echo "Triggering Windows-side setup at: $CMD_WIN_PATH"
echo "Watch for the UAC dialog on your Windows desktop."

CMD_EXE="$(command -v cmd.exe || true)"
if [ -z "$CMD_EXE" ]; then
  for candidate in \
    /mnt/c/Windows/System32/cmd.exe \
    /mnt/c/WINDOWS/System32/cmd.exe
  do
    if [ -x "$candidate" ]; then
      CMD_EXE="$candidate"
      break
    fi
  done
fi

if [ -z "$CMD_EXE" ]; then
  echo "ERROR: cmd.exe not found. Ensure WSL Windows interop is enabled." >&2
  exit 1
fi

exec "$CMD_EXE" /c "$CMD_WIN_PATH" "$@"
