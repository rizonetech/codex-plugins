#!/usr/bin/env bash
# chromemcp-run — evidence wrapper that delegates to the installed safe_runner.py.
# The infrastructure lives at ~/ChromeMCP; install it from:
#   git clone https://github.com/rizonetech/ChromeMCP && bash scripts/install.sh --from-source
set -euo pipefail

CHROMEMCP_HOME="${CHROMEMCP_HOME:-$HOME/ChromeMCP}"
SAFE_RUNNER="$CHROMEMCP_HOME/mcp/client/safe_runner.py"
export MCP_URL="${MCP_URL:-http://127.0.0.1:8941/mcp}"
export MCP_TOKEN_PATH="${MCP_TOKEN_PATH:-${XDG_CONFIG_HOME:-$HOME/.config}/chromemcp-codex/token}"

if [ ! -f "$SAFE_RUNNER" ]; then
  echo "chromemcp-run: safe_runner.py not found at $SAFE_RUNNER" >&2
  echo "Install ChromeMCP:" >&2
  echo "  git clone https://github.com/rizonetech/ChromeMCP" >&2
  echo "  bash scripts/install.sh --from-source" >&2
  exit 127
fi

exec env PYTHONPATH="$CHROMEMCP_HOME" python3 -m mcp.client.safe_runner "$@"
