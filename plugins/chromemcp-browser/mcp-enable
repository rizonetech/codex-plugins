#!/usr/bin/env bash
# Install + enable + start the chromemcp systemd user unit so the MCP server
# auto-restarts on crash and survives logout (via linger).
#
# Requires:
#   * systemd as PID 1 inside the WSL distro (set [boot] systemd=true in
#     /etc/wsl.conf and run `wsl --shutdown` once on the Windows side).
#   * systemd 235+ for `%h` expansion (not used here — we render absolute
#     paths into the unit at install time so the unit is portable).
#
# After running this:
#   * `./mcp-up`        starts via systemd
#   * `./mcp-down`      stops via systemd
#   * `./mcp-status`    shows `systemctl --user status`
#   * `journalctl --user -u chromemcp -f`  tails the live log
#   * crash → restart in ~3s + startup time (≤10s typical)
set -euo pipefail

SELF="$(readlink -f "$0")"
REPO_ROOT="$(dirname "$SELF")"
UNIT_NAME="chromemcp.service"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
UNIT_PATH="$UNIT_DIR/$UNIT_NAME"
TEMPLATE="$REPO_ROOT/launcher/chromemcp.service.template"

if [ ! -r "$TEMPLATE" ]; then
  echo "ERROR: unit template not found at $TEMPLATE" >&2
  exit 1
fi

# Sanity: systemd must be running so `systemctl --user` actually works.
if ! systemctl --user is-system-running >/dev/null 2>&1; then
  STATE="$(systemctl --user is-system-running 2>&1 || true)"
  echo "ERROR: 'systemctl --user is-system-running' reports: $STATE" >&2
  echo "  ChromeMCP supervision requires systemd inside this WSL distro." >&2
  echo "  Add the following to /etc/wsl.conf and run 'wsl --shutdown' from Windows:" >&2
  echo "    [boot]" >&2
  echo "    systemd=true" >&2
  exit 1
fi

mkdir -p "$UNIT_DIR"

# Render template: replace the __REPO_ROOT__ marker with this repo's absolute path.
sed "s|__REPO_ROOT__|$REPO_ROOT|g" "$TEMPLATE" > "$UNIT_PATH.tmp"
mv "$UNIT_PATH.tmp" "$UNIT_PATH"
chmod 0644 "$UNIT_PATH"
echo "Installed unit: $UNIT_PATH"

systemctl --user daemon-reload

# If the unit is already active from a previous install, stop it first so
# daemon-reload picks up any ExecStart path changes cleanly.
if systemctl --user is-active --quiet "$UNIT_NAME"; then
  echo "Existing service is active; restarting to pick up new unit..."
  systemctl --user restart "$UNIT_NAME"
else
  systemctl --user enable --now "$UNIT_NAME"
fi

# Linger lets the service keep running after the user logs out / closes
# their last WSL shell. Without linger, the user systemd instance is torn
# down on last logout and the service dies with it.
if ! loginctl show-user "$USER" --property=Linger 2>/dev/null | grep -q 'Linger=yes'; then
  echo "Enabling linger for $USER (lets the service survive logout)..."
  # loginctl enable-linger may require sudo on some systems; try unprivileged first.
  if loginctl enable-linger "$USER" 2>/dev/null; then
    echo "  linger enabled."
  else
    echo "  WARN: 'loginctl enable-linger $USER' failed (likely needs sudo)." >&2
    echo "  Run:  sudo loginctl enable-linger $USER" >&2
    echo "  Without linger, the service stops on last logout — fine for foreground dev." >&2
  fi
fi

echo ""
systemctl --user status "$UNIT_NAME" --no-pager --lines=10 || true
echo ""
echo "ChromeMCP is now managed by systemd."
echo "  Tail logs:     journalctl --user -u $UNIT_NAME -f"
echo "  Stop/start:    ./mcp-down  /  ./mcp-up   (route through systemctl)"
echo "  Disable:       ./mcp-disable"
