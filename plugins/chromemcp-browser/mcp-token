#!/usr/bin/env bash
# Print (and lazily create) the ChromeMCP MCP auth token.
#
# Usage:
#   ./mcp-token              # print current token (generate if missing)
#   ./mcp-token --path       # print the token file path only
#   ./mcp-token --rotate     # generate a fresh token (replaces existing)
#   ./mcp-token --header     # print 'Authorization: Bearer <token>' for curl
#
# The token is stored at $XDG_CONFIG_HOME/chromemcp/token (default
# ~/.config/chromemcp/token) with mode 0600.
set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
TOKEN_DIR="$CONFIG_HOME/chromemcp"
TOKEN_PATH="${MCP_TOKEN_PATH:-$TOKEN_DIR/token}"

MODE="show"
for arg in "$@"; do
  case "$arg" in
    --path)    MODE="path" ;;
    --rotate)  MODE="rotate" ;;
    --header)  MODE="header" ;;
    --help|-h)
      sed -n '1,12p' "$0"; exit 0 ;;
    *) echo "ERROR: unknown arg: $arg" >&2; exit 64 ;;
  esac
done

generate_token() {
  mkdir -p "$TOKEN_DIR"
  chmod 700 "$TOKEN_DIR"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 32 > "$TOKEN_PATH"
  elif [ -r /dev/urandom ]; then
    head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n' > "$TOKEN_PATH"
    printf '\n' >> "$TOKEN_PATH"
  else
    echo "ERROR: no openssl and no /dev/urandom — cannot generate token" >&2
    exit 1
  fi
  chmod 600 "$TOKEN_PATH"
}

case "$MODE" in
  path)
    echo "$TOKEN_PATH"
    ;;
  rotate)
    generate_token
    echo "Rotated token at $TOKEN_PATH. Restart the MCP server (./mcp-down && ./mcp-up) for it to take effect." >&2
    cat "$TOKEN_PATH"
    ;;
  show|header)
    if [ ! -s "$TOKEN_PATH" ]; then
      generate_token
      echo "Generated new token at $TOKEN_PATH" >&2
    fi
    TOKEN="$(cat "$TOKEN_PATH" | tr -d '\n\r ')"
    if [ "$MODE" = "header" ]; then
      printf 'Authorization: Bearer %s\n' "$TOKEN"
    else
      printf '%s\n' "$TOKEN"
    fi
    ;;
esac
